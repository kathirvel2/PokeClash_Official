# ---------------------------------------------------------------------------
# PokeClash environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env` for local development:
#     cp .env.example .env
# ...then fill in real values. NEVER commit a filled-in .env / .env.production.
#
# The bot picks which file to load based on ENV_MODE (see main.py):
#   ENV_MODE=production  -> loads .env.production
#   anything else/unset  -> loads .env
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) -------------------------------------------------
# For a LOCAL Postgres instance, DB_SSLMODE=disable and DB_SSLCERT is unused.
# For a managed cloud DB (e.g. Aiven), set DB_SSLMODE=require and point
# DB_SSLCERT at the provider's CA certificate file (kept OUT of git).
DB_HOST=127.0.0.1
DB_NAME=pokemon_db
DB_USER=myuser
DB_PASS=mypassword
DB_PORT=5432
DB_SSLMODE=disable
# DB_SSLCERT=ca.pem            # only needed when DB_SSLMODE=require

# --- Telegram bot ----------------------------------------------------------
# Get a token from @BotFather. Keep it secret; anyone with it controls the bot.
BOT_TOKEN=123456789:REPLACE_WITH_YOUR_BOTFATHER_TOKEN
BOT_USERNAME=YourBot_bot

# --- Web app / mini-app ----------------------------------------------------
# Public URL where the website/ dex mini-app is served (Render, Cloudflare
# Tunnel, etc.). Used for CORS and Telegram WebApp links.
WEB_APP_HOST_URL="https://your-app.example.com"
WEB_APP_LINK_NAME=YourWebAppName

# --- Ranked / community wiring --------------------------------------------
# Comma-separated Telegram group IDs where ranked play is allowed.
RANKED_GROUP_IDS="-1000000000000,-1000000000001"
COMMUNITY_CHAT_ID="-1000000000000"
COMMUNITY_CHAT_LINK="https://t.me/your_community"

# --- Admin / ops -----------------------------------------------------------
# Comma-separated Telegram user IDs with admin privileges.
ADMIN_USER_IDS=000000000
# Chat ID the bot sends database backups to.
BACKUP_CHAT_ID=-000000000

# --- Showdown (optional overrides) ----------------------------------------
# Path to the bundled Pokemon Showdown install; defaults to
# server/pokemon-showdown relative to the repo root if unset.
# SHOWDOWN_DIR=
# SHOWDOWN_OWNED_FORMAT=gen9pokeclashcompetitive
